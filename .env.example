# ─────────────────────────────────────────────────────────────
# AI Medical Vision Platform — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- General ---
APP_ENV=development                 # development | staging | production
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                      # true in prod for structured logs

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
API_SECRET_KEY=change-me-in-production-please-32chars-min

# --- Database ---
# Production: postgresql+asyncpg://user:pass@host:5432/db
# Zero-infra dev fallback (no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./dev.sqlite3

# --- Redis (optional in dev; falls back to in-memory) ---
REDIS_URL=redis://localhost:6379/0

# --- Storage abstraction ---
# STORAGE_BACKEND: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage
# S3 / R2 (when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# --- Auth (Clerk) ---
# Backend verifies Clerk-issued JWTs via JWKS. In dev, DEV_AUTH_BYPASS
# lets you work without a Clerk account (a fake dev user is injected).
DEV_AUTH_BYPASS=true
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=

# --- AI / LLM (provider-agnostic) ---
# The whole app talks to AIService only. Swap providers by changing AI_PROVIDER.
# If the selected provider has no key, it falls back to a mock (dev/CI safe).
# Options: openai | anthropic | gemini | azure_openai | ollama | openrouter | mock
AI_PROVIDER=openai
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1024

# OpenAI (default)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Stronger vision model for image analysis (narration/chat use OPENAI_MODEL)
OPENAI_VISION_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# Ollama (local, OpenAI-compatible; no key)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Medical Vision Platform
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
