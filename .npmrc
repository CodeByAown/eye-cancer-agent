# Use a hoisted (flat, npm-style) node_modules layout.
# Next.js + ESLint 8 have transitive deps (e.g. eslint-visitor-keys) that pnpm's
# default isolated store can fail to expose, breaking `next lint`. A hoisted
# linker resolves this deterministically and matches CI behavior.
node-linker=hoisted
strict-peer-dependencies=false
auto-install-peers=true
